{
	"manifest_version": 3,
	"name": "MastoGale",
	"version": "1.0.0",
	"description": "简洁、易用的长毛象客户端.",
	"icons": {
		"256": "icons/256.png",
		"128": "icons/128.png",
		"48": "icons/48.png",
		"40": "icons/40.png",
		"38": "icons/38.png",
		"19": "icons/19.png",
		"16": "icons/16.png"
	},
	"background": {
		"service_worker": "service-worker.js"
	},
	"content_scripts": [ {
		"js": [ "js/lib/jquery-min.js", "js/consumer-helper.js" ],
		"matches": [ "https://fanfou.com/apps.details/*" ],
		"run_at": "document_end"
	} ],
	"action": {
		"default_icon": {
			"38": "icons/38.png",
			"19": "icons/19.png"
		},
		"default_popup": "popup.html",
		"default_title": "MastoGale"
	},
	"options_page": "options.html",
	"omnibox": { "keyword": "f" },
	"permissions": [
		"tabs",
		"contextMenus",
		"notifications",
		"offscreen",
		"storage",
		"scripting"
	],
	"host_permissions": [
		"<all_urls>"
	],
	"web_accessible_resources": [
		{
			"resources": ["manifest.json", "login.html"],
			"matches": ["<all_urls>"]
		}
	],
	"content_security_policy": {
		"extension_pages": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: http:; connect-src 'self' data: https: http:"
	},
	"minimum_chrome_version": "88"
}
